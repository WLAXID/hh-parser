# Конфигурация для тестирования rate limits HH API
# Скопируйте этот файл в .env и заполните значения

# Access token для авторизации в HH API
# Можно получить через OAuth авторизацию
HH_ACCESS_TOKEN=

# Опционально: Refresh token для обновления access token
# HH_REFRESH_TOKEN=

# Опционально: Client ID и Secret для OAuth
# HH_CLIENT_ID=
# HH_CLIENT_SECRET=
